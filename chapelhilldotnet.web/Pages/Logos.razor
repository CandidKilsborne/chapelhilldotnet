@page "/logos"

<PageTitle>Logo Concepts | Chapel Hill .NET</PageTitle>

<section class="page-hero">
    <div class="hero-card hero-card--about">
        <div class="hero-card__grid">
            <div class="hero-card__content">
                <span class="eyebrow eyebrow--light">Temporary review page</span>
                <h1 class="hero-card__title">Logo directions for Chapel Hill .NET.</h1>
                <p class="hero-card__lede">
                    This page collects the current mark, the earlier local variant, and four additional concepts so you can
                    compare them in one place before we pick a direction to refine.
                </p>

                <dl class="hero-metrics">
                    <div>
                        <dt>Total concepts</dt>
                        <dd>@LogoConcepts.Count</dd>
                    </div>
                    <div>
                        <dt>New additions</dt>
                        <dd>4 fresh directions</dd>
                    </div>
                    <div>
                        <dt>Goal</dt>
                        <dd>Find the strongest Chapel Hill tie-in</dd>
                    </div>
                </dl>
            </div>

            <aside class="hero-spotlight" aria-label="Logo review guidance">
                <p class="hero-spotlight__label">What to watch for</p>
                <h2>Pick the concept that feels local, distinct, and durable.</h2>
                <ul class="hero-spotlight__list">
                    <li>Does it feel specific to Chapel Hill instead of generic developer branding?</li>
                    <li>Does it still read clearly at header and favicon size?</li>
                    <li>Does it feel like a community mark, not a company logo?</li>
                </ul>
            </aside>
        </div>
    </div>
</section>

<section class="page-section">
    <div class="page-shell">
        <div class="section-heading">
            <div class="section-heading__content">
                <span class="eyebrow">Concept gallery</span>
                <h2 class="section-title">Six options, each pushing the identity in a different direction.</h2>
                <p class="section-lede">
                    Every card includes a larger preview plus light and dark interface swatches so the marks can be judged in a
                    more realistic setting.
                </p>
            </div>
        </div>

        <div class="logo-grid">
            @foreach (var logo in LogoConcepts)
            {
                <article class="section-card logo-option-card">
                    <div class="logo-option-card__topline">
                        <span class="eyebrow">@logo.Label</span>
                        @if (logo.IsCurrent)
                        {
                            <span class="logo-status-pill">Current active</span>
                        }
                    </div>

                    <div class="logo-preview-stage">
                        <img src="@logo.Path" alt="@($"{logo.Name} concept preview")" class="logo-preview-stage__image" loading="lazy" />
                    </div>

                    <div class="logo-swatch-grid" aria-label="@($"{logo.Name} light and dark previews")">
                        <figure class="logo-swatch">
                            <div class="logo-swatch__canvas logo-swatch__canvas--light">
                                <img src="@logo.Path" alt="" loading="lazy" />
                            </div>
                            <figcaption>Light UI</figcaption>
                        </figure>

                        <figure class="logo-swatch">
                            <div class="logo-swatch__canvas logo-swatch__canvas--dark">
                                <img src="@logo.Path" alt="" loading="lazy" />
                            </div>
                            <figcaption>Dark UI</figcaption>
                        </figure>
                    </div>

                    <div class="logo-option-card__content">
                        <h3>@logo.Name</h3>
                        <p class="story-copy">@logo.Description</p>

                        <ul class="story-list logo-notes">
                            @foreach (var note in logo.Notes)
                            {
                                <li>@note</li>
                            }
                        </ul>
                    </div>
                </article>
            }
        </div>
    </div>
</section>

<section class="page-section page-section--muted">
    <div class="page-shell page-shell--compact">
        <div class="cta-panel">
            <div>
                <span class="eyebrow">Next step</span>
                <h2 class="section-title">Once you pick a direction, I can refine it instead of spreading effort across six drafts.</h2>
                <p class="section-lede">
                    After that, I can turn the winner into the active header mark, favicon, social card badge, and a horizontal wordmark if needed.
                </p>
            </div>

            <div class="cta-panel__actions">
                <a class="site-button site-button--primary" href="/">Back to the public site</a>
                <a class="site-button site-button--secondary" href="/events">See the logo in context</a>
            </div>
        </div>
    </div>
</section>

@code {
