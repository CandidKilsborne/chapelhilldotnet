@page "/Error"
@using System.Diagnostics
@using Microsoft.AspNetCore.Http

<PageTitle>Error</PageTitle>

<section class="page-section">
    <div class="page-shell page-shell--compact">
        <div class="section-card story-panel" role="alert" aria-live="assertive">
            <span class="eyebrow">Application error</span>
            <h1 class="section-title">We could not load that page.</h1>
            <p class="section-lede">
                An unexpected error occurred while processing the request. Reload the page or return to the main site and try again.
            </p>

            @if (ShowRequestId)
            {
                <p class="story-copy">
                    <strong>Request ID:</strong> <code>@RequestId</code>
                </p>
            }

            <div class="value-grid">
                <div class="value-card">
                    <h2>Development mode</h2>
                    <p>
                        Detailed diagnostics are only shown when the app is running with
                        <strong>ASPNETCORE_ENVIRONMENT</strong> set to <strong>Development</strong>.
                    </p>
                </div>
                <div class="value-card">
                    <h2>Production safety</h2>
                    <p>
                        Development mode should stay disabled in deployed environments because detailed exception pages
                        can expose sensitive information.
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>

@code{
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}
