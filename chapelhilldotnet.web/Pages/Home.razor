@page "/"

<PageTitle>Chapel Hill .NET | Chapel Hill, NC developer community</PageTitle>

<section class="page-hero">
    <div class="hero-card hero-card--home">
        <div class="hero-card__grid">
            <div class="hero-card__content">
                <span class="eyebrow eyebrow--light">Developer community in Chapel Hill, North Carolina</span>
                <h1 class="hero-card__title">Connect, learn, and build better .NET software together.</h1>
                <p class="hero-card__lede">
                    Chapel Hill .NET is a meetup for developers working across .NET, Azure, Blazor, cloud delivery,
                    automation, and the day-to-day craft of shipping modern applications.
                </p>

                <div class="hero-card__actions">
                    <a class="site-button site-button--hero" href="/events">See upcoming events</a>
                    <a class="site-button site-button--ghost" href="/about">Learn how the group works</a>
                </div>

                <dl class="hero-metrics">
                    <div>
                        <dt>Format</dt>
                        <dd>Talks, coworking, workshops</dd>
                    </div>
                    <div>
                        <dt>Focus</dt>
                        <dd>.NET, Azure, Blazor, delivery</dd>
                    </div>
                    <div>
                        <dt>Audience</dt>
                        <dd>Open to every skill level</dd>
                    </div>
                </dl>
            </div>

            <aside class="hero-spotlight" aria-label="Community highlights">
                <p class="hero-spotlight__label">Next gathering</p>

                @if (FeaturedEvent is not null)
                {
                    <h2>@FeaturedEvent.Title</h2>
                    <p class="hero-spotlight__date">@FeaturedEvent.Date.ToString("dddd, MMMM d")</p>
                    <p class="hero-spotlight__copy">@FeaturedEvent.Description</p>

                    <div class="hero-spotlight__meta">
                        <span>@FeaturedEvent.Location</span>

                        @if (!string.IsNullOrWhiteSpace(FeaturedEvent.Time))
                        {
                            <span>@FeaturedEvent.Time</span>
                        }
                    </div>
                }
                else
                {
                    <h2>Fresh meetup details are on the way.</h2>
                    <p class="hero-spotlight__copy">Check back soon for the next Chapel Hill .NET session.</p>
                }

                <ul class="hero-spotlight__list">
                    <li>Technical sessions with practical takeaways.</li>
                    <li>Conversations with local builders and teams.</li>
                    <li>A welcoming space for new and experienced developers.</li>
                </ul>
            </aside>
        </div>
    </div>
</section>

<section id="about" class="page-section">
    <div class="page-shell">
        <div class="section-heading">
            <div class="section-heading__content">
                <span class="eyebrow">What we explore</span>
                <h2 class="section-title">A practical mix of application development, cloud delivery, and developer tools.</h2>
                <p class="section-lede">
                    The group stays grounded in the Microsoft stack while making room for adjacent tools and ideas that
                    help teams build and operate software more effectively.
                </p>
            </div>
        </div>

        <div class="feature-grid">
            <article class="tech-feature-card">
                <div class="tech-icon-wrapper">
                    <Blazicon Svg="DeviconOriginal.Dotnetcore" class="tech-icon" />
                </div>
                <div>
                    <h3>.NET development</h3>
                    <p class="item-description">From C# language improvements to ASP.NET Core patterns and maintainable service design.</p>
                </div>
            </article>

            <article class="tech-feature-card">
                <div class="tech-icon-wrapper">
                    <Blazicon Svg="DeviconOriginal.Azure" class="tech-icon" />
                </div>
                <div>
                    <h3>Azure cloud</h3>
                    <p class="item-description">Real-world platform guidance around hosting, identity, deployment, and observability.</p>
                </div>
            </article>

            <article class="tech-feature-card">
                <div class="tech-icon-wrapper">
                    <Blazicon Svg="DeviconOriginal.Blazor" class="tech-icon" />
                </div>
                <div>
                    <h3>Blazor interfaces</h3>
                    <p class="item-description">Patterns for building fast, polished web experiences with C# end to end.</p>
                </div>
            </article>

            <article class="tech-feature-card">
                <div class="tech-icon-wrapper">
                    <Blazicon Svg="DeviconOriginal.Csharp" class="tech-icon" />
                </div>
                <div>
                    <h3>C# craftsmanship</h3>
                    <p class="item-description">Language features, testing strategies, and architectural tradeoffs that hold up in production.</p>
                </div>
            </article>

            <article class="tech-feature-card">
                <div class="tech-icon-wrapper">
                    <Blazicon Svg="DeviconOriginal.Powershell" class="tech-icon" />
                </div>
                <div>
                    <h3>Automation</h3>
                    <p class="item-description">Tooling, scripts, and workflows that remove busywork and help teams move faster.</p>
                </div>
            </article>

            <article class="tech-feature-card">
                <div class="tech-icon-wrapper">
                    <Blazicon Svg="DeviconOriginal.Pytorch" class="tech-icon" />
                </div>
                <div>
                    <h3>Applied AI and data</h3>
                    <p class="item-description">Practical conversations about machine learning, intelligent apps, and modern developer workflows.</p>
                </div>
            </article>
        </div>
    </div>
</section>

<section id="events" class="page-section page-section--muted">
    <div class="page-shell">
        <div class="section-heading">
            <div class="section-heading__content">
                <span class="eyebrow">Upcoming meetups</span>
                <h2 class="section-title">A calendar designed for learning, conversation, and repeat attendance.</h2>
                <p class="section-lede">
                    The upcoming lineup balances hands-on sessions, architecture discussions, and lower-pressure coworking time.
                </p>
            </div>

            <div class="section-heading__action">
                <a class="site-button site-button--secondary" href="/events">View the full events page</a>
            </div>
        </div>

        <div class="card-grid card-grid--events">
            @foreach (var evt in Events)
            {
                <EventCard Event="@evt" />
            }
        </div>
    </div>
</section>

<section id="organizers" class="page-section">
    <div class="page-shell">
        <div class="section-heading">
            <div class="section-heading__content">
                <span class="eyebrow">Organizers</span>
                <h2 class="section-title">A community run by people who care about practical, durable engineering.</h2>
                <p class="section-lede">
                    The group is built by local organizers who want clear talks, useful follow-up conversations, and a community that stays approachable.
                </p>
            </div>

            <div class="section-heading__action">
                <a class="site-button site-button--secondary" href="/organizers">See the organizer page</a>
            </div>
        </div>

        <div class="card-grid card-grid--organizers">
            @foreach (var organizer in Organizers)
            {
                <OrganizerCard Organizer="@organizer" />
            }
        </div>
    </div>
</section>

<section class="page-section page-section--compressed">
    <div class="page-shell">
        <div class="sponsor-feature">
            <div class="sponsor-feature__content">
                <span class="eyebrow">Sponsors</span>
                <h2 class="section-title">Community support that helps the group stay active.</h2>
                <p class="section-lede">
                    We are grateful for the companies and community partners who make meetup space, logistics, and momentum possible.
                </p>
            </div>

            <div class="sponsor-card sponsor-card--featured">
                <div class="sponsor-info">
                    <img src="images/sponsors/artificial_pixel_logo.svg" alt="Artificial Pixel, LLC Logo" class="sponsor-logo" />
                    <div>
                        <h3 class="sponsor-name">Artificial Pixel, LLC</h3>
                        <p class="item-description">Supporting local software craftsmanship and community-driven learning.</p>
                    </div>
                </div>

                <a href="https://artificialpixel.com" target="_blank" rel="noopener noreferrer" class="site-button site-button--secondary">
                    Visit sponsor
                </a>
            </div>
        </div>
    </div>
</section>

@code {
    private List<Event> Events { get; set; } = [];
    private List<Organizer> Organizers { get; set; } = [];
    private Event? FeaturedEvent => Events.OrderBy(evt => evt.Date).FirstOrDefault();

    protected override void OnInitialized()
    {
        Events = EventsList.Events;
        Organizers = OrganizersList.Organizers;
    }
}
