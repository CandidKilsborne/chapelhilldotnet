@page "/admin/events"
@layout AdminLayout
@inject IEventService EventService
@inject IAuthenticationService AuthService
@inject NavigationManager Navigation

<PageTitle>Admin Events | Chapel Hill .NET</PageTitle>

<div class="admin-page">
    <section class="page-hero">
        <div class="hero-card hero-card--admin">
            <div class="hero-card__grid">
                <div class="hero-card__content">
                    <span class="eyebrow eyebrow--light">Admin workspace</span>
                    <h1 class="hero-card__title">Manage the event calendar from one workspace built for quick updates.</h1>
                    <p class="hero-card__lede">
                        Review, update, and publish event details without digging through multiple screens or losing track
                        of what attendees will see on the public site.
                    </p>

                    <div class="hero-card__actions">
                        <a href="/admin/events/new" class="site-button site-button--hero" aria-label="Add new event">Add event</a>
                        <a href="/" class="site-button site-button--ghost">View public site</a>
                        <button type="button"
                                @onclick="HandleLogout"
                                class="site-button site-button--ghost admin-ghost-danger"
                                aria-label="Logout from admin panel">
                            Logout
                        </button>
                    </div>
                </div>

                <aside class="hero-spotlight" aria-label="Event management summary">
                    <p class="hero-spotlight__label">Workspace summary</p>
                    <h2>@SummaryHeading</h2>

                    @if (!string.IsNullOrEmpty(_currentUser))
                    {
                        <div class="hero-spotlight__meta">
                            <span>Signed in as @_currentUser</span>
                        </div>
                    }

                    <dl class="hero-metrics admin-metrics">
                        <div>
                            <dt>Upcoming</dt>
                            <dd>@UpcomingEventsCount</dd>
                        </div>
                        <div>
                            <dt>Archived</dt>
                            <dd>@PastEventsCount</dd>
                        </div>
                        <div>
                            <dt>Seats</dt>
                            <dd>@TotalExpectedAttendees</dd>
                        </div>
                    </dl>
                </aside>
            </div>
        </div>
    </section>

    <section class="page-section">
        <div class="page-shell">
            @if (_isLoading)
            {
                <div class="section-card admin-empty">
                    <h2>Loading events...</h2>
                    <p class="story-copy">Fetching the current meetup schedule.</p>
                </div>
            }
            else
            {
                <div class="admin-toolbar">
                    <div>
                        <span class="eyebrow">Calendar contents</span>
                        <h2 class="section-title">All events</h2>
                        <p class="section-lede">Review the full schedule, catch outdated details, and jump straight into edits.</p>
                    </div>

                    <div class="admin-toolbar__actions">
                        <a href="/admin/events/new" class="site-button site-button--secondary">Create event</a>
                    </div>
                </div>

                @if (!_events.Any())
                {
                    <div class="section-card admin-empty">
                        <h2>No events found</h2>
                        <p class="story-copy">Create your first event to populate the public calendar.</p>
                        <a href="/admin/events/new" class="site-button site-button--primary">Create first event</a>
                    </div>
                }
                else
                {
                    <div class="section-card admin-table-card">
                        <div class="admin-table-shell">
                            <table class="admin-table" aria-label="Events management table">
                                <thead>
                                    <tr>
                                        <th scope="col">Title</th>
                                        <th scope="col">Date</th>
                                        <th scope="col">Location</th>
                                        <th scope="col">Attendees</th>
                                        <th scope="col" class="admin-table__actions-header">Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var evt in _events.OrderBy(evt => evt.Date))
                                    {
                                        <tr>
                                            <td>
                                                <div class="admin-table__primary">@evt.Title</div>
                                                @if (!string.IsNullOrWhiteSpace(evt.Description))
                                                {
                                                    <div class="admin-table__secondary">@evt.Description</div>
                                                }
                                            </td>
                                            <td>
                                                <div class="admin-table__primary">
                                                    <time datetime="@evt.Date.ToString("yyyy-MM-dd")">@evt.Date.ToString("MMM d, yyyy")</time>
                                                </div>
                                                @if (!string.IsNullOrWhiteSpace(evt.Time))
                                                {
                                                    <div class="admin-table__secondary">@evt.Time</div>
                                                }
                                            </td>
                                            <td>
                                                <div class="admin-table__primary">@evt.Location</div>
                                            </td>
                                            <td>
                                                <div class="admin-table__primary">@evt.Attendees</div>
                                            </td>
                                            <td class="admin-table__actions">
                                                <a href="/admin/events/edit/@evt.Id"
                                                   class="admin-action"
                                                   aria-label="Edit event @evt.Title">
                                                    Edit
                                                </a>
                                                <button type="button"
                                                        @onclick="() => ConfirmDelete(evt)"
                                                        class="admin-action admin-action--danger"
                                                        aria-label="Delete event @evt.Title">
                                                    Delete
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
            }
        </div>
    </section>
</div>

@if (_showDeleteConfirm && _eventToDelete != null)
{
    <div class="admin-modal-backdrop" @onclick="CancelDelete">
        <div class="admin-modal" role="dialog" aria-labelledby="delete-title" aria-modal="true" @onclick:stopPropagation="true">
            <h2 id="delete-title">Delete event</h2>
            <p class="story-copy">
                Are you sure you want to delete "@_eventToDelete.Title"? This action cannot be undone.
            </p>

            <div class="admin-form-actions">
                <button type="button"
                        @onclick="CancelDelete"
                        class="site-button site-button--secondary">
                    Cancel
                </button>
                <button type="button"
                        @onclick="DeleteEvent"
                        class="site-button site-button--danger">
                    Delete event
                </button>
            </div>
        </div>
    </div>
}

@code {
    private List<Event> _events = new();
    private string? _currentUser;
    private bool _isLoading = true;
    private bool _showDeleteConfirm;
    private Event? _eventToDelete;
    private string SummaryHeading => _isLoading
        ? "Loading the current calendar..."
        : _events.Count == 0
            ? "No events in the system yet."
            : $"{_events.Count} events currently in the calendar.";
    private int UpcomingEventsCount => _events.Count(evt => evt.Date.Date >= DateTime.Today);
    private int PastEventsCount => _events.Count - UpcomingEventsCount;
    private int TotalExpectedAttendees => _events.Sum(evt => evt.Attendees);

    protected override async Task OnInitializedAsync()
    {
        var isAuthenticated = await AuthService.IsAuthenticatedAsync();
        if (!isAuthenticated)
        {
            Navigation.NavigateTo("/admin/login");
            return;
        }

        _currentUser = await AuthService.GetCurrentUserAsync();
        await LoadEvents();
    }

    private async Task LoadEvents()
    {
        _isLoading = true;
        _events = await EventService.GetAllEventsAsync();
        _isLoading = false;
    }

    private async Task HandleLogout()
    {
        await AuthService.LogoutAsync();
        Navigation.NavigateTo("/admin/login");
    }

    private void ConfirmDelete(Event evt)
    {
        _eventToDelete = evt;
        _showDeleteConfirm = true;
    }

    private void CancelDelete()
    {
        _eventToDelete = null;
        _showDeleteConfirm = false;
    }

    private async Task DeleteEvent()
    {
        if (_eventToDelete != null)
        {
            await EventService.DeleteEventAsync(_eventToDelete.Id);
            await LoadEvents();
        }

        _eventToDelete = null;
        _showDeleteConfirm = false;
    }
}
