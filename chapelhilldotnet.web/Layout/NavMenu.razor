<header class="site-header-wrap" role="banner">
    <div class="site-header">
        <div class="site-header__inner">
            <a class="site-brand" href="/">
                <span class="site-brand__mark" aria-hidden="true">
                    <img src="images/branding/chapel-hill-dotnet-mark.svg" alt="" />
                </span>
                <span class="site-brand__text">
                    <span class="site-brand__eyebrow">Chapel Hill, NC</span>
                    <span class="site-brand__name">Chapel Hill .NET</span>
                </span>
            </a>

            <button class="site-nav-toggle"
                    @onclick="ToggleNavMenu"
                    type="button"
                    aria-label="Toggle navigation menu"
                    aria-expanded="@(!collapseNavMenu)"
                    aria-controls="main-navigation">
                <span class="site-nav-toggle__bar"></span>
                <span class="site-nav-toggle__bar"></span>
                <span class="site-nav-toggle__bar"></span>
            </button>

            <div class="@NavMenuCssClass" id="main-navigation">
                <nav class="site-nav" aria-label="Main navigation">
                    <NavLink class="site-nav__link" href="" Match="NavLinkMatch.All" @onclick="CloseNavMenu">Home</NavLink>
                    <NavLink class="site-nav__link" href="events" @onclick="CloseNavMenu">Events</NavLink>
                    <NavLink class="site-nav__link" href="about" @onclick="CloseNavMenu">About</NavLink>
                    <NavLink class="site-nav__link" href="organizers" @onclick="CloseNavMenu">Organizers</NavLink>
                    <NavLink class="site-nav__link site-nav__link--admin" href="admin/events" @onclick="CloseNavMenu">Admin</NavLink>
                </nav>

                <div class="site-header__actions">
                    <DarkModeToggle />
                    <a class="site-button site-button--primary" href="events" @onclick="CloseNavMenu">Attend a Meetup</a>
                </div>
            </div>
        </div>
    </div>
</header>

@code {
    private bool collapseNavMenu = true;

    private string NavMenuCssClass => collapseNavMenu ? "site-header__menu" : "site-header__menu is-open";

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }

    private void CloseNavMenu()
    {
        collapseNavMenu = true;
    }
}
