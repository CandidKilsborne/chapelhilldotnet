@page "/events"

<PageTitle>Events | Chapel Hill .NET</PageTitle>

<section class="page-hero">
    <div class="hero-card hero-card--events">
        <div class="hero-card__grid">
            <div class="hero-card__content">
                <span class="eyebrow eyebrow--light">Events and programming</span>
                <h1 class="hero-card__title">A steady calendar for developers who want practical conversations.</h1>
                <p class="hero-card__lede">
                    The event schedule mixes evening talks, working sessions, and focused discussions across .NET, Azure,
                    front-end quality, architecture, and the tooling around modern delivery.
                </p>

                <dl class="hero-metrics">
                    <div>
                        <dt>Upcoming</dt>
                        <dd>@_upcomingEvents.Count sessions</dd>
                    </div>
                    <div>
                        <dt>Archive</dt>
                        <dd>@_pastEvents.Count recent meetups</dd>
                    </div>
                    <div>
                        <dt>Cadence</dt>
                        <dd>Recurring local programming</dd>
                    </div>
                </dl>
            </div>

            <aside class="hero-spotlight">
                <p class="hero-spotlight__label">Speaker-friendly format</p>
                <h2>Talks, demos, and collaborative working time.</h2>
                <ul class="hero-spotlight__list">
                    <li>Technical talks that stay grounded in implementation details.</li>
                    <li>Smaller sessions that make it easier to ask questions and compare approaches.</li>
                    <li>Room for local teams and individual builders to share what they have learned.</li>
                </ul>
            </aside>
        </div>
    </div>
</section>

<section id="upcoming" class="page-section">
    <div class="page-shell">
        <div class="section-heading">
            <div class="section-heading__content">
                <span class="eyebrow">Upcoming events</span>
                <h2 class="section-title">What is on deck for the next stretch of the meetup calendar.</h2>
                <p class="section-lede">
                    Each session is designed to give people something concrete to take back to their own work.
                </p>
            </div>
        </div>

        <div class="card-grid card-grid--events">
            @foreach (var upcomingEvent in _upcomingEvents)
            {
                <EventCard Event="@upcomingEvent" />
            }
        </div>
    </div>
</section>

<section id="past" class="page-section page-section--muted">
    <div class="page-shell">
        <div class="section-heading">
            <div class="section-heading__content">
                <span class="eyebrow">Recent archive</span>
                <h2 class="section-title">A quick look at the kinds of sessions the group has hosted.</h2>
                <p class="section-lede">
                    The archive gives newcomers a sense of the technical range and tone of the meetup.
                </p>
            </div>
        </div>

        <div class="archive-grid">
            @foreach (var pastEvent in _pastEvents)
            {
                <article class="section-card archive-card">
                    <time class="archive-card__date" datetime="@pastEvent.Date.ToString("yyyy-MM-dd")">
                        @pastEvent.Date.ToString("MMMM d, yyyy")
                    </time>
                    <h3>@pastEvent.Title</h3>
                    <p class="story-copy">@pastEvent.Location</p>
                    <span class="archive-card__pill">Resources coming soon</span>
                </article>
            }
        </div>
    </div>
</section>

<section class="page-section">
    <div class="page-shell">
        <div class="cta-panel">
            <div>
                <span class="eyebrow">Call for speakers</span>
                <h2 class="section-title">Have a topic worth sharing with the local .NET community?</h2>
                <p class="section-lede">
                    We are always interested in sessions that explain how something was built, debugged, migrated, or improved.
                </p>
            </div>

            <div class="cta-panel__actions">
                <a class="site-button site-button--primary" href="/#organizers">Talk with an organizer</a>
                <a class="site-button site-button--secondary" href="/about">See what the group is about</a>
            </div>
        </div>
    </div>
</section>

@code {
    private readonly List<Event> _upcomingEvents = [];
    private readonly List<Event> _pastEvents =
    [
        new()
        {
            Id = 4,
            Title = "Shipping Better Blazor Forms",
            Date = DateTime.Today.AddDays(-24),
            Location = "Chapel Hill Public Library"
        },
        new()
        {
            Id = 5,
            Title = "Observability Basics for Azure App Services",
            Date = DateTime.Today.AddDays(-51),
            Location = "Launch Chapel Hill"
        },
        new()
        {
            Id = 6,
            Title = "Designing .NET APIs for Front-End Teams",
            Date = DateTime.Today.AddDays(-86),
            Location = "Virtual meetup"
        }
    ];

    protected override void OnInitialized()
    {
        _upcomingEvents.AddRange(EventsList.Events.OrderBy(evt => evt.Date));
    }
}
