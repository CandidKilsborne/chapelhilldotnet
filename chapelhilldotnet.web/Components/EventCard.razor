<article class="community-card event-card">
    <div class="event-card__meta">
        <span class="event-card__badge">Upcoming</span>
        <time datetime="@Event.Date.ToString("yyyy-MM-dd")">@Event.Date.ToString("MMMM d, yyyy")</time>
    </div>

    <h3 class="event-card__title">@Event.Title</h3>
    <p class="event-card__description">@Event.Description</p>

    <dl class="event-card__details">
        <div>
            <dt>Where</dt>
            <dd>@Event.Location</dd>
        </div>

        @if (!string.IsNullOrWhiteSpace(Event.Time))
        {
            <div>
                <dt>When</dt>
                <dd>@Event.Time</dd>
            </div>
        }

        @if (Event.Attendees > 0)
        {
            <div>
                <dt>Seats</dt>
                <dd>@Event.Attendees expected</dd>
            </div>
        }
    </dl>
</article>

@code {
    [Parameter] public required Event Event { get; set; }
}
