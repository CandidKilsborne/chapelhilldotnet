@page "/admin/events/new"
@page "/admin/events/edit/{EventId:int}"
@layout AdminLayout
@inject IEventService EventService
@inject IAuthenticationService AuthService
@inject NavigationManager Navigation

<PageTitle>@(EventId.HasValue ? "Edit Event" : "New Event") | Chapel Hill .NET Admin</PageTitle>

<div class="admin-page">
    <section class="page-hero">
        <div class="hero-card hero-card--admin">
            <div class="hero-card__grid">
                <div class="hero-card__content">
                    <span class="eyebrow eyebrow--light">Event editor</span>
                    <h1 class="hero-card__title">@(EventId.HasValue ? "Refine an existing meetup entry." : "Create the next event in the calendar.")</h1>
                    <p class="hero-card__lede">
                        Keep the public site current with clear titles, accurate logistics, and descriptions that help people decide to attend.
                    </p>

                    <div class="hero-card__actions">
                        <a href="/admin/events" class="site-button site-button--hero">Back to events</a>
                    </div>
                </div>

                <aside class="hero-spotlight" aria-label="Editing guidance">
                    <p class="hero-spotlight__label">Editing checklist</p>
                    <h2>Make the public event card easy to scan.</h2>
                    <ul class="hero-spotlight__list">
                        <li>Lead with a clear, specific title.</li>
                        <li>Use descriptions that explain the value of attending.</li>
                        <li>Double-check the date, time, and location before saving.</li>
                    </ul>
                </aside>
            </div>
        </div>
    </section>

    <section class="page-section">
        <div class="page-shell page-shell--compact">
            @if (_isLoading)
            {
                <div class="section-card admin-empty">
                    <h2>Loading event editor...</h2>
                    <p class="story-copy">Preparing the form and current event data.</p>
                </div>
            }
            else
            {
                <div class="admin-form-card admin-form-card--editor">
                    <div class="admin-form-card__header">
                        <span class="eyebrow">Event details</span>
                        <h2>@(EventId.HasValue ? "Edit event" : "New event")</h2>
                        <p>These fields control how the meetup appears in the public event list.</p>
                    </div>

                    <EditForm Model="@_eventModel" OnValidSubmit="@HandleSubmit" FormName="eventForm">
                        <DataAnnotationsValidator />

                        @if (!string.IsNullOrEmpty(_errorMessage))
                        {
                            <div class="admin-alert admin-alert--error" role="alert">
                                @_errorMessage
                            </div>
                        }

                        <div class="admin-form-grid">
                            <div class="admin-field">
                                <label for="title" class="admin-label">Title <span class="admin-required">*</span></label>
                                <InputText id="title"
                                           @bind-Value="_eventModel.Title"
                                           class="admin-input"
                                           placeholder="Event title"
                                           aria-required="true" />
                                <ValidationMessage For="@(() => _eventModel.Title)" class="validation-message" />
                            </div>

                            <div class="admin-field">
                                <label for="description" class="admin-label">Description</label>
                                <InputTextArea id="description"
                                               @bind-Value="_eventModel.Description"
                                               rows="5"
                                               class="admin-input admin-input--textarea"
                                               placeholder="Describe what people will learn or discuss." />
                                <ValidationMessage For="@(() => _eventModel.Description)" class="validation-message" />
                            </div>

                            <div class="admin-form-grid admin-form-grid--split">
                                <div class="admin-field">
                                    <label for="date" class="admin-label">Date <span class="admin-required">*</span></label>
                                    <InputDate id="date"
                                               @bind-Value="_eventModel.Date"
                                               class="admin-input"
                                               aria-required="true" />
                                    <ValidationMessage For="@(() => _eventModel.Date)" class="validation-message" />
                                </div>

                                <div class="admin-field">
                                    <label for="time" class="admin-label">Time</label>
                                    <InputText id="time"
                                               @bind-Value="_eventModel.Time"
                                               class="admin-input"
                                               placeholder="6:00 PM - 8:00 PM" />
                                    <ValidationMessage For="@(() => _eventModel.Time)" class="validation-message" />
                                </div>
                            </div>

                            <div class="admin-field">
                                <label for="location" class="admin-label">Location <span class="admin-required">*</span></label>
                                <InputText id="location"
                                           @bind-Value="_eventModel.Location"
                                           class="admin-input"
                                           placeholder="Event location"
                                           aria-required="true" />
                                <ValidationMessage For="@(() => _eventModel.Location)" class="validation-message" />
                            </div>

                            <div class="admin-field">
                                <label for="attendees" class="admin-label">Expected attendees</label>
                                <InputNumber id="attendees"
                                             @bind-Value="_eventModel.Attendees"
                                             class="admin-input"
                                             placeholder="0" />
                                <ValidationMessage For="@(() => _eventModel.Attendees)" class="validation-message" />
                            </div>

                            <div class="admin-form-actions">
                                <a href="/admin/events" class="site-button site-button--secondary">Cancel</a>
                                <button type="submit"
                                        class="site-button site-button--primary"
                                        disabled="@_isSaving"
                                        aria-label="@(EventId.HasValue ? "Update event" : "Create event")">
                                    @if (_isSaving)
                                    {
                                        <span>Saving...</span>
                                    }
                                    else
                                    {
                                        <span>@(EventId.HasValue ? "Update event" : "Create event")</span>
                                    }
                                </button>
                            </div>
                        </div>
                    </EditForm>
                </div>
            }
        </div>
    </section>
</div>

@code {
    [Parameter]
    public int? EventId { get; set; }

    private EventModel _eventModel = new();
    private string? _errorMessage;
    private bool _isLoading = true;
    private bool _isSaving;

    protected override async Task OnInitializedAsync()
    {
        var isAuthenticated = await AuthService.IsAuthenticatedAsync();
        if (!isAuthenticated)
        {
            Navigation.NavigateTo("/admin/login");
            return;
        }

        if (EventId.HasValue)
        {
            var evt = await EventService.GetEventByIdAsync(EventId.Value);
            if (evt != null)
            {
                _eventModel = new EventModel
                {
                    Id = evt.Id,
                    Title = evt.Title,
                    Description = evt.Description,
                    Date = evt.Date,
                    Time = evt.Time,
                    Location = evt.Location,
                    Attendees = evt.Attendees
                };
            }
            else
            {
                Navigation.NavigateTo("/admin/events");
                return;
            }
        }
        else
        {
            _eventModel.Date = DateTime.Today;
        }

        _isLoading = false;
    }

    private async Task HandleSubmit()
    {
        _isSaving = true;
        _errorMessage = null;

        try
        {
            var evt = new Event
            {
                Id = _eventModel.Id,
                Title = _eventModel.Title,
                Description = _eventModel.Description,
                Date = _eventModel.Date,
                Time = _eventModel.Time,
                Location = _eventModel.Location,
                Attendees = _eventModel.Attendees
            };

            if (EventId.HasValue)
            {
                await EventService.UpdateEventAsync(evt);
            }
            else
            {
                await EventService.CreateEventAsync(evt);
            }

            Navigation.NavigateTo("/admin/events");
        }
        catch (Exception ex)
        {
            _errorMessage = $"An error occurred: {ex.Message}";
        }
        finally
        {
            _isSaving = false;
        }
    }

    public class EventModel
    {
        public int Id { get; set; }

        [Required(ErrorMessage = "Title is required")]
        public string Title { get; set; } = string.Empty;

        public string? Description { get; set; }

        [Required(ErrorMessage = "Date is required")]
        public DateTime Date { get; set; }

        public string Time { get; set; } = string.Empty;

        [Required(ErrorMessage = "Location is required")]
        public string Location { get; set; } = string.Empty;

        [Range(0, int.MaxValue, ErrorMessage = "Attendees must be a positive number")]
        public int Attendees { get; set; }
    }
}
