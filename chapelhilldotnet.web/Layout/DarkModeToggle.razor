@inject IJSRuntime JsRuntime

<button @onclick="ToggleDarkMode"
        type="button"
        class="theme-toggle"
        aria-label="@(IsDarkMode ? "Switch to light mode" : "Switch to dark mode")"
        aria-pressed="@IsDarkMode.ToString().ToLowerInvariant()">
    <span class="theme-toggle__icon" aria-hidden="true">
        @if (IsDarkMode)
        {
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                 aria-hidden="true" focusable="false">
                <circle cx="12" cy="12" r="4" />
                <path d="M12 2v2" />
                <path d="M12 20v2" />
                <path d="M4.93 4.93l1.41 1.41" />
                <path d="M17.66 17.66l1.41 1.41" />
                <path d="M2 12h2" />
                <path d="M20 12h2" />
                <path d="M4.93 19.07l1.41-1.41" />
                <path d="M17.66 6.34l1.41-1.41" />
            </svg>
        }
        else
        {
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                 aria-hidden="true" focusable="false">
                <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z" />
            </svg>
        }
    </span>
    <span class="theme-toggle__label">@(IsDarkMode ? "Dark" : "Light")</span>
</button>

<div role="status" aria-live="polite" aria-atomic="true" class="sr-only">
    @if (isInteractive)
    {
        <span>@(IsDarkMode ? "Dark mode enabled" : "Light mode enabled")</span>
    }
</div>

@code {
    private bool IsDarkMode { get; set; }
    private bool isInteractive;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        var theme = await JsRuntime.InvokeAsync<string?>("themePreference.get");
        IsDarkMode = string.Equals(theme, "dark", StringComparison.OrdinalIgnoreCase);
        isInteractive = true;
        StateHasChanged();
    }

    private async Task ToggleDarkMode()
    {
        IsDarkMode = !IsDarkMode;
        await JsRuntime.InvokeVoidAsync("themePreference.set", IsDarkMode ? "dark" : "light");
    }
}
